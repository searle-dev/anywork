# ╔══════════════════════════════════════════════════════════════╗
# ║  AnyWork Configuration                                     ║
# ║  Copy to .env and fill in your values                      ║
# ╚══════════════════════════════════════════════════════════════╝

# === LLM Provider (Claude Code native variables) ===
# AnyWork uses Claude Code's native ANTHROPIC_* environment variables.
# All ANTHROPIC_* and CLAUDE_* vars are auto-collected and passed to workers.

# --- Option A: Anthropic Official API ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Option B: Third-party OpenAI-compatible provider (e.g. OpenRouter) ---
# Claude Code requires ANTHROPIC_AUTH_TOKEN for the actual API key,
# ANTHROPIC_BASE_URL for the endpoint, and ANTHROPIC_API_KEY="" (empty) to
# signal non-native mode.
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_AUTH_TOKEN=sk-or-xxxxx
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-20250514

# --- Model overrides (optional) ---
# ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_DEFAULT_HAIKU_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-4-6

# === Title Generation (optional, independent from worker LLM) ===
# Falls back to ANTHROPIC_AUTH_TOKEN → ANTHROPIC_API_KEY for the key,
# and ANTHROPIC_BASE_URL for the endpoint.
# TITLE_API_KEY=sk-or-xxxxx
# TITLE_API_BASE_URL=https://openrouter.ai/api/v1
# TITLE_MODEL=openai/gpt-4o-mini

# === Server ===
SERVER_PORT=3001
JWT_SECRET=change-me-in-production

# === Worker ===
WORKER_PORT=8080
WORKER_IMAGE=anywork-worker:latest

# === Storage ===
# local | filestore
STORAGE_DRIVER=local
LOCAL_DATA_DIR=/data/users

# === Container Scheduler ===
# static (docker-compose) | docker (per-user) | k8s (multi-user, recommended)
CONTAINER_DRIVER=static

# === Kubernetes Driver (CONTAINER_DRIVER=k8s) ===
# Namespace where worker Pods and Services are created
K8S_NAMESPACE=anywork

# Workspace storage mode:
#   emptydir  – ephemeral per-session workspace (simplest, no PVC needed)
#   pvc       – persistent per-user PVC (files survive session restarts)
K8S_WORKSPACE_STORAGE=emptydir

# StorageClass for PVCs (only used when K8S_WORKSPACE_STORAGE=pvc)
# K8S_PVC_STORAGE_CLASS=standard

# Worker Pod resource limits
K8S_CPU_REQUEST=250m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=2Gi

# Seconds before an idle worker Pod is garbage-collected (0 = disabled)
K8S_IDLE_TTL_SECONDS=1800

# === Database ===
DATABASE_URL=sqlite:///data/anywork.db

# === Google Cloud (Phase 2) ===
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# FILESTORE_IP=
# FILESTORE_SHARE=anywork_share
